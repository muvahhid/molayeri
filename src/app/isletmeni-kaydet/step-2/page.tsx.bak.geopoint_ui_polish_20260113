"use client";
import { useWizardStepGuard } from "@/lib/wizard/stepGuard";
import * as React from "react";
import { useRouter } from "next/navigation";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { useWizard } from "../wizard.provider";

type PlaceItem = { description: string; place_id: string };

function normalizeTitle(s: string) {
  return s
    .replace(/\s+/g, " ")
    .trim()
    .replace(/^./, (c) => c.toUpperCase());
}

function extractRoadNameFromAddress(addr: string): string {
  const up = String(addr || "").toUpperCase();
  const m =
    up.match(/\bO-\s*\d+\b/) ||
    up.match(/\bE\s*\d{1,3}\b/) ||
    up.match(/\bD\s*\d{1,3}\b/) ||
    up.match(/\bTEM\b/) ||
    up.match(/\bE-?5\b/);
  if (!m) return "";
  return m[0].replace(/\s+/g, "").replace("E-5", "E5");
}

function extractRoadCodes(input: string): string[] {
  const src = String(input || "").toUpperCase();
  const out: string[] = [];
  const seen = new Set<string>();

  const push = (v: string) => {
    const x = String(v || "").trim();
    if (!x) return;
    if (seen.has(x)) return;
    seen.add(x);
    out.push(x);
  };

  // TEM
  if (/\bTEM\b/.test(src)) push("TEM");

  // E80, E-80, E 80
  for (const m of src.matchAll(/\bE\s*-?\s*(\d{2,3})\b/g)) {
    const n = Number(m[1]);
    if (Number.isFinite(n)) push(`E${String(n).padStart(2, "0")}`);
  }

  // D100, D-100, D 100
  for (const m of src.matchAll(/\bD\s*-?\s*(\d{2,3})\b/g)) {
    const n = Number(m[1]);
    if (Number.isFinite(n)) push(`D${String(n).padStart(3, "0")}`);
  }

  // O-4 / O4 / O 4  -> O-4
  for (const m of src.matchAll(/\bO\s*-?\s*(\d{1,2})\b/g)) {
    const n = Number(m[1]);
    if (Number.isFinite(n)) push(`O-${n}`);
  }

  return out;
}

function bearingToText(b: number | null) {
  if (typeof b !== "number" || !Number.isFinite(b)) return "";
  const deg = ((b % 360) + 360) % 360;
  const dirs = [
    { n: "Kuzey",  a: 0 },
    { n: "Kuzeydoğu", a: 45 },
    { n: "Doğu",   a: 90 },
    { n: "Güneydoğu", a: 135 },
    { n: "Güney",  a: 180 },
    { n: "Güneybatı", a: 225 },
    { n: "Batı",   a: 270 },
    { n: "Kuzeybatı", a: 315 },
  ];
  // en yakın 45'lik dilim
  const idx = Math.round(deg / 45) % 8;
  return `${dirs[idx].n} (${Math.round(deg)}°)`;
}

async function fetchBearing(lat: number, lng: number): Promise<number | null> {
  try {
    const r = await fetch(`/api/osmr/bearing?lat=${encodeURIComponent(String(lat))}&lng=${encodeURIComponent(String(lng))}`, { cache: "no-store" });
    if (!r.ok) return null;
    const j = await r.json();
    const b = Number(j?.bearing);
    return Number.isFinite(b) ? b : null;
  } catch {
    return null;
  }
}

type Selected = { addressText: string; lat: number | null; lng: number | null };

export default function Step2IsletmeBilgileriPage() {
  useWizardStepGuard(2);
  const router = useRouter();
  const { state, setBusiness } = useWizard();

  const [q, setQ] = React.useState(state.business.addressText || "");
  const [results, setResults] = React.useState<PlaceItem[]>([]);
  const [token, setToken] = React.useState("");
  const [err, setErr] = React.useState<string | null>(null);

  const selectedRef = React.useRef<Selected>({
    addressText: state.business.addressText || "",
    lat: state.business.lat,
    lng: state.business.lng,
  });

  const [geoLat, setGeoLat] = React.useState<string>(
    state.business.geoPoint ? String(state.business.geoPoint.lat) : "",
  );
  const [geoText, setGeoText] = React.useState<string>(
    state.business.geoPoint ? `${state.business.geoPoint.lat}, ${state.business.geoPoint.lng}` : ""
  );
  const [geoLng, setGeoLng] = React.useState<string>(
    state.business.geoPoint ? String(state.business.geoPoint.lng) : "",
  );

  React.useEffect(() => {
    try {
      const sp = new URLSearchParams(window.location.search);
      if (sp.get("new") === "1")
        window.localStorage.removeItem("molayeri_wizard_v1");
    } catch {}

    try {
      const raw = window.localStorage.getItem("molayeri_session_v1");
      const ss = raw ? JSON.parse(raw) : null;
      const uid = String(ss?.uid || "").trim();
      if (!uid) {
        window.location.href = "/login";
        return;
      }
    } catch {
      window.location.href = "/login";
      return;
    }

    setToken(Math.random().toString(36).slice(2));
  }, []);

  function clearSelected() {
    selectedRef.current = { addressText: "", lat: null, lng: null };
    setBusiness({
      addressText: "",
      lat: null,
      lng: null,
      geoPoint: null,
      bearing: null,
    });
    setGeoLat("");
    setGeoLng("");
  }

  async function searchPlaces(v: string) {
    if (v.length < 6) {
      setResults([]);
      return;
    }
    try {
      const r = await fetch(
        `/api/places/autocomplete?input=${encodeURIComponent(v)}&token=${encodeURIComponent(token)}`,
        { cache: "no-store" },
      );
      const j = await r.json();
      setResults((j.predictions || []).slice(0, 6));
    } catch {
      setResults([]);
    }
  }

  async function selectPlace(item: PlaceItem) {
    try {
      const r = await fetch(
        `/api/places/details?place_id=${encodeURIComponent(item.place_id)}&token=${encodeURIComponent(token)}`,
        { cache: "no-store" },
      );
      const j = await r.json();

      const g = j.result?.geometry?.location;
      const formatted = j.result?.formatted_address || item.description;

      const latNum = Number(g?.lat);
      const lngNum = Number(g?.lng);
      const lat = Number.isFinite(latNum) ? latNum : null;
      const lng = Number.isFinite(lngNum) ? lngNum : null;

      selectedRef.current = { addressText: formatted, lat, lng };
      const autoRoad = extractRoadNameFromAddress(formatted);
      const nextRoadName = (state.business.roadName || "").trim()
        ? state.business.roadName
        : autoRoad || "";
      setBusiness({
        addressText: formatted,
        lat,
        lng,
        geoPoint:
          typeof lat === "number" && typeof lng === "number" ? { lat, lng } : null,
        roadName: nextRoadName,
        roadCodes: extractRoadCodes((formatted || "") + " " + nextRoadName),
      });

      if (typeof lat === "number" && typeof lng === "number") {
        setGeoLat(String(lat));
        setGeoLng(String(lng));
        setGeoText(`${lat}, ${lng}`);
      }

      // ✅ otomatik bearing (yol yönü)
      if (typeof lat === "number" && typeof lng === "number") {
        const b = await fetchBearing(lat, lng);
        if (typeof b === "number") setBusiness({ bearing: b });
      }
      setResults([]);

      setErr(null);

      setQ(formatted);
    } catch {}
  }

  function next() {
    if (!state.business.name.trim()) return setErr("İşletme adı zorunlu.");

    const s = selectedRef.current;
    if (!s.addressText || s.lat === null || s.lng === null) {
      return setErr("Adres listeden seçilmeli.");
    }

    setErr(null);
    router.push("/isletmeni-kaydet/step-3");
  }

  return (
    <div className="px-6 pb-6">
      <div className="text-2xl font-black">İşletme Bilgileri</div>
      <div className="mt-2 text-sm text-white/60">İşletmeni tanımla.</div>

      <div className="mt-6 space-y-4">
        <Input
          label="İşletme Adı"
          placeholder="ÖRN: MOLAYERİ AKARYAKIT"
          value={state.business.name}
          maxLength={30}
          onChange={(e) =>
            setBusiness({
              name: e.target.value
                .toUpperCase()
                .replace(/\s+/g, " ")
                .trimStart(),
            })
          }
          hint="En fazla 30 karakter."
        />

        <div className="relative">
          <Input
            label="Adres"
            placeholder="İşletme adınızı yazarak arayın ve listeden seçin."
            value={q}
            onChange={async (e) => {
              const v = e.target.value;
              setQ(v);
              clearSelected();
              if (v.length < 6) {
                setResults([]);
                return;
              }
              await searchPlaces(v);
            }}
          />

          {results.length > 0 && (
            <div className="absolute left-0 right-0 z-50 mt-2 overflow-hidden rounded-2xl border border-white/10 bg-[#151A24] shadow-[0_18px_55px_rgba(0,0,0,0.45)]">
              {results.map((r) => (
                <button
                  key={r.place_id}
                  type="button"
                  onMouseDown={(e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    void selectPlace(r);
                  }}
                  className="block w-full px-4 py-3 text-left text-sm text-white hover:bg-white/5"
                >
                  {r.description}
                </button>
              ))}

            </div>
          )}
        </div>

<div className="mt-4">
  <div className="text-sm text-white/70 leading-relaxed">
    Sayın işletmeci; Google haritalar bazen hata yapıp buraya işletmenizin doğru olmayan konumnu çekiyor.
    3 adımda en doğru konum için:
    <span className="font-semibold text-white/85"> 1-</span> Yandaki harita butonuna tıklayın
    <span className="font-semibold text-white/85"> 2-</span> İşletmenizin geçtiği yolun tam ortasına sağ tıklayın
    <span className="font-semibold text-white/85"> 3-</span> En üstte çıkan rakamlara tıkladığınızda otomatik kopyalanır, bu boşluğa yapıştırın.
  </div>

  <div className="mt-3 flex flex-col gap-2 md:flex-row md:items-end">
    <div className="flex-1">
      <Input
        label="Giriş Noktası Koordinatı"
        placeholder="40.123456, 29.123456"
        value={geoText}
        onChange={(e) => {
          const t = e.target.value;
          setGeoText(t);

          const parts = t.trim().split(/[,\s]+/).filter(Boolean);
          if (parts.length >= 2) {
            const latNum = Number(parts[0]);
            const lngNum = Number(parts[1]);
            if (Number.isFinite(latNum) && Number.isFinite(lngNum)) {
              setGeoLat(String(latNum));
              setGeoLng(String(lngNum));
              setBusiness({ geoPoint: { lat: latNum, lng: lngNum } });
              return;
            }
          }

          setBusiness({ geoPoint: null });
        }}
        hint="Google Haritalar: yola sağ tık → en üstteki koordinatı (tek satır) yapıştır."
      />
    </div>

    <Button
      type="button"
      variant="ghost"
      className="h-11 md:mb-[22px]"
      onClick={() => {
        const addr = (state.business.addressText || q || "").trim();
        const url = addr
          ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(addr)}`
          : "https://www.google.com/maps";
        window.open(url, "_blank", "noopener,noreferrer");
      }}
    >
      Harita
    </Button>
  </div>
</div>

          <div className="mt-3 rounded-2xl border border-white/10 bg-white/5 p-4">
          <div className="mb-3 text-sm font-semibold text-white">
            İşletme Yol Tarifi
          </div>
          <div className="mb-3 text-xs text-white/60">
            Otomatik yön: <span className="text-white/80 font-semibold">{bearingToText(state.business.bearing) || "-"}</span>
          </div>
          <div className="grid grid-cols-1 gap-3 md:grid-cols-2">
            <Input
              label="Yol İsmi"
              placeholder="Yol ismi örn. E80"
              value={state.business.roadName}
              maxLength={12}
              onChange={(e) =>
                setBusiness({
                  roadName: e.target.value
                    .toUpperCase()
                    .replace(/\s+/g, " ")
                    .trimStart(),
                  roadCodes: extractRoadCodes(e.target.value),
                })
              }
            />
            <Input
              label="Tarif"
              placeholder="örn. Ankara yönü, cadde ismi, okul yanı, vb  max20 kr."
              value={state.business.roadNote}
              maxLength={20}
              onChange={(e) =>
                setBusiness({
                  roadNote: e.target.value.replace(/\s+/g, " ").trimStart(),
                  roadCodes: extractRoadCodes(e.target.value),
                })
              }
            />
          </div>
          <div className="mt-3 text-xs font-bold text-white/70">
            *İşletmeniz ana yol üzerinde ise yol ismi yazmanız hayati öneme
            sahiptir. Kullanıcı deneyimi ve işletmenizin bulunabilirliği ciddi
            oranda yükselir.
          </div>
        </div>

        {state.business.addressText ? (
          <div className="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/70">
            Seçilen adres: {state.business.addressText}
          </div>
        ) : null}

        <label className="block">
          <div className="mb-2 text-sm font-semibold text-white">
            Tanıtım Yazısı
          </div>
          <textarea
            className="w-full h-32 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-white/35 outline-none focus:border-[#D9A400]/40 focus:ring-2 focus:ring-[#D9A400]/15 resize-none"
            placeholder="Kısa işletme tanıtımı"
            maxLength={200}
            value={state.business.description}
            onChange={(e) => setBusiness({ description: e.target.value })}
            onBlur={(e) =>
              setBusiness({ description: normalizeTitle(e.target.value) })
            }
          />
          <div className="mt-2 text-xs text-white/60">
            En fazla 200 karakter.
          </div>
        </label>
      </div>

      {err ? (
        <div className="mt-4 text-sm font-bold text-[#FF4D4F]">{err}</div>
      ) : null}

      <div className="mt-6 flex items-center justify-between">
        <Button variant="secondary" onClick={() => router.back()}>
          Geri
        </Button>
        <Button
          variant="primary"
          onClick={next}
          className="px-8 py-4 rounded-[22px]"
        >
          İleri: Kategori & Özellikler
        </Button>
      </div>
    </div>
  );
}
